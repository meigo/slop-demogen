{
  "name": "@meigo/demogen",
  "version": "0.1.0",
  "description": "Record repo-committed demo GIFs/MP4s of web apps via Playwright + ffmpeg.",
  "type": "module",
  "license": "MIT",
  "author": "meigo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meigo/slop-demogen.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "demogen": "bin/demogen.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "demo:record": "node ./dist/cli.js",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "dependencies": {
    "minimatch": "^10.0.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "playwright": "^1.40.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
